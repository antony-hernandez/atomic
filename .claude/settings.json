{
  "mcpServers": {
    "codegraph": {
      "command": "npx",
      "args": [
        "-y",
        "@colbymchenry/codegraph@latest",
        "serve"
      ],
      "env": {}
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 packages/cli/hooks/check-template-bump.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}